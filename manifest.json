{
  "manifest_version": 3,
  "name": "PeopleSoft GPA Overlay",
  "description": "Calculates and overlays weighted GPA above grades tables.",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": [
        "https://student.uwo.ca/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
